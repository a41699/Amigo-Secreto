# Chave secreta para encriptação (32 bytes em hex = 64 caracteres)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here_replace_with_secure_random_value
ADMIN_AUTH_SECRET=another_secure_32_byte_hex_key_here

# Porta do servidor
PORT=3000

# CORS - URLs permitidas para o frontend
CORS_ORIGIN=http://localhost:4200

# Admin inicial (criado automaticamente se a tabela admins estiver vazia)
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=sua_password
MYSQL_DATABASE=amigo_secreto
